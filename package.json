{
  "name": "express-template",
  "version": "1.0.2",
  "description": "Express.js 模板项目，使用 TypeScript 编写，集成 Prisma ORM。",
  "main": "build/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node build/app.js",
    "test": "pnpm run typecheck",
    "lint": "tsc --noEmit",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:db:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.21",
    "md5": "^2.3.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "svg-captcha": "^1.4.0",
    "ts-node": "^10.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/lodash-es": "^4.17.12",
    "@types/md5": "^2.3.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.10",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
